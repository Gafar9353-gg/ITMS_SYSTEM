generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?

  users User[]
}

model Department {
  id      Int    @id @default(autoincrement())
  name    String
  code    String

  users User[]
}

model User {
  id            Int      @id @default(autoincrement())
  fullName      String
  email         String   @unique
  password      String
  mobile        String?

  roleId        Int
  departmentId  Int?

  role          Role @relation(fields: [roleId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}